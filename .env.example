LINE_CHANNEL_ACCESS_TOKEN=
LINE_USER_ID=
DATABASE_URL=postgresql://user:password@host:port/dbname
LOG_LEVEL=INFO
DAILY_REPORT_JST=09:00
# Optional: 両方セットすると PROXY_HOSTS 対象 URL を Supabase edge function (Tokyo) 経由で fetch する。
# 未設定時は直接 fetch (GHA US ランナーから 403 を食う可能性あり)。
# 詳細は supabase/functions/fetch-jp/DEPLOY.md 参照。
SUPABASE_FETCH_JP_URL=
SUPABASE_FETCH_JP_KEY=
